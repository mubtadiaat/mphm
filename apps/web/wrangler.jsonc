{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mphm-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "m.p3hm.my.id",
      "custom_domain": true
    }
  ],
  "vars": {
    "NEXT_PUBLIC_API_URL": "https://api.m.p3hm.my.id",
    "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME": "r9f9o3jm"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  }
}
